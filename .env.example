# StockBrief API Server local environment

# MySQL
MYSQL_ROOT_PASSWORD=stockbrief-root-password
MYSQL_USER=stockbrief
MYSQL_PASSWORD=stockbrief-password
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=stockbrief

# PostgreSQL / pgvector
POSTGRES_USER=stockbrief
POSTGRES_PASSWORD=stockbrief-password
POSTGRES_DB=stockbrief_vector
PG_HOST=localhost
PG_PORT=5432
PG_USER=stockbrief
PG_PASSWORD=stockbrief-password
PG_DATABASE=stockbrief_vector

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=stockbrief-redis-password
REDIS_DB=0

# Local app
DEBUG=false
COOKIE_SECURE=false
AUTH_SECRET=change-this-local-secret
AUTH_PASSWORD=change-this-local-password
ADMIN_SECRET_CODE=
CORS_ALLOWED_FRONTEND_URL=http://localhost:3000
FRONTEND_AUTH_CALLBACK_URL=http://localhost:3000/auth-callback

# Local first-run defaults: keep external jobs disabled until API keys are issued.
STOCK_AUTO_SYNC_ENABLED=false
PIPELINE_SCHEDULER_ENABLED=false
PROFILE_SCHEDULER_ENABLED=false
PROACTIVE_BRIEFING_SCHEDULER_ENABLED=false
HEATMAP_REDIS_CACHE_ENABLED=true
PIPELINE_STATE_REDIS_ENABLED=true

# AI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_RESPONSES_MODEL=gpt-5-mini
LANGGRAPH_MODEL=gpt-4.1-mini

# Kakao OAuth
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:33333/kakao-authentication/request-access-token-after-redirection

# Data providers
DART_API_KEY=
SERP_API_KEY=
FINNHUB_API_KEY=
TWELVE_DATA_API_KEY=
DATA_GO_KR_SERVICE_KEY=
NAVER_CLIENT_ID=
NAVER_SECRET=
YOUTUBE_API_KEY=
TWITTER_BEARER_TOKEN=
